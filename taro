def load_apps() -> list[dict]:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(DEFAULT_APPS, indent=2))
    return list(DEFAULT_APPS)


def save_apps(apps: list[dict]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(apps, indent=2))


def in_multiplexer() -> bool:
    return (
        "TMUX" in os.environ
        or os.environ.get("TERM_PROGRAM") == "tmux"
        or "BYOBU_BACKEND" in os.environ
        or "BYOBU_WINDOW_NAME" in os.environ
    )


def launch_command(command: str) -> None:
    if in_multiplexer():
        subprocess.Popen(["tmux", "new-window", command])
    else:
        os.execvp("sh", ["sh", "-c", command])


class AppIcon(Static, can_focus=True):
    """A single desktop icon tile."""

    BINDINGS = [
        Binding("enter", "launch", "Launch"),
        Binding("e", "edit", "Edit"),
        Binding("delete", "delete_app", "Delete"),
    ]

    def __init__(self, app_data: dict, index: int, **kwargs) -> None:
        self._app_data = app_data
        self._index = index
        super().__init__(**kwargs)
        self._update_content()

    def _update_content(self) -> None:
        icon = self._app_data.get("icon", "▶")
        name = self._app_data.get("name", "App")
        self.update(f"{icon}\n\n[bold]{name}[/bold]")

    def refresh_data(self, app_data: dict) -> None:
        self._app_data = app_data
        self._update_content()

    def on_enter(self, event: events.Enter) -> None:
        self.focus()

    def on_click(self, event: events.Click) -> None:
        event.stop()
        if event.button == 3:
            self.app.open_context_menu(self._index)
        else:
            self.action_launch()

    def action_launch(self) -> None:
        self.app.do_launch(self._app_data["command"])

    def action_edit(self) -> None:
        self.app.open_edit(self._index)

    def action_delete_app(self) -> None:
        self.app.open_delete(self._index)


class AddEditModal(ModalScreen):
    """Add or edit an app entry."""

    BINDINGS = [Binding("escape", "dismiss", "Cancel")]

    def __init__(self, app_data: dict | None = None, index: int = -1, **kwargs) -> None:
        super().__init__(**kwargs)
        self._app_data = app_data or {}
        self._index = index
        self._editing = app_data is not None

    def compose(self) -> ComposeResult:
        title = "Edit App" if self._editing else "Add App"
        with Container(id="modal-container"):
            yield Label(title, classes="modal-title")
            yield Label("Icon (emoji or character)", classes="field-label")
            yield Input(
                value=self._app_data.get("icon", "▶"),
                placeholder="▶",
                id="icon-input",
                classes="field-input",
            )
            yield Label("", id="icon-preview", classes="icon-preview")
            yield Label("Name", classes="field-label")
            yield Input(
                value=self._app_data.get("name", ""),
                placeholder="My App",
                id="name-input",
                classes="field-input",
            )
            yield Label("Command", classes="field-label")
            yield Input(
                value=self._app_data.get("command", ""),
                placeholder="bash -c '...'",
                id="cmd-input",
                classes="field-input",
            )
            with Horizontal(classes="modal-buttons"):
                yield Button("Cancel", id="cancel-btn", classes="btn-cancel")
                label = "Save" if self._editing else "Add"
                yield Button(label, id="save-btn", classes="btn-primary")

    def on_mount(self) -> None:
        self._update_preview()
        self.query_one("#icon-input").focus()

    def on_input_changed(self, event: Input.Changed) -> None:
        if event.input.id == "icon-input":
            self._update_preview()

    def _update_preview(self) -> None:
        icon = self.query_one("#icon-input", Input).value or "▶"
        preview = self.query_one("#icon-preview", Label)
        preview.update(f"[bold]{icon}[/bold]")

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "cancel-btn":
            self.dismiss(None)
        elif event.button.id == "save-btn":
            icon = self.query_one("#icon-input", Input).value.strip() or "▶"
            name = self.query_one("#name-input", Input).value.strip()
            command = self.query_one("#cmd-input", Input).value.strip()
            if not name or not command:
                return
            self.dismiss({"icon": icon, "name": name, "command": command})


class ReorderModal(ModalScreen):
    """Reorder all apps via a keyboard-navigable list."""

    BINDINGS = [
        Binding("escape", "dismiss", "Cancel"),
        Binding("up", "move_up", "Up", show=False),
        Binding("down", "move_down", "Down", show=False),
    ]

    def __init__(self, apps: list[dict], **kwargs) -> None:
        super().__init__(**kwargs)
        self._apps = [dict(a) for a in apps]
        self._cursor = 0

    def compose(self) -> ComposeResult:
        with Container(id="reorder-container"):
            yield Label("Reorder Apps", classes="modal-title")
            yield Label("↑↓ move  •  Enter confirm  •  Esc cancel", classes="reorder-hint")
            yield Static(id="reorder-list")
            with Horizontal(classes="modal-buttons"):
                yield Button("Cancel", id="cancel-btn", classes="btn-cancel")
                yield Button("Save", id="save-btn", classes="btn-primary")

    def on_mount(self) -> None:
        self._render_list()

    def _render_list(self) -> None:
        lines = []
        for i, app in enumerate(self._apps):
            icon = app.get("icon", "▶")
            name = app.get("name", "App")
            if i == self._cursor:
                lines.append(f"[bold reverse] {icon} {name} [/bold reverse]")
            else:
                lines.append(f"  {icon} {name}")
        self.query_one("#reorder-list", Static).update("\n".join(lines))

    def action_move_up(self) -> None:
        if self._cursor > 0:
            self._apps[self._cursor], self._apps[self._cursor - 1] = (
                self._apps[self._cursor - 1],
                self._apps[self._cursor],
            )
            self._cursor -= 1
            self._render_list()

    def action_move_down(self) -> None:
        if self._cursor < len(self._apps) - 1:
            self._apps[self._cursor], self._apps[self._cursor + 1] = (
                self._apps[self._cursor + 1],
                self._apps[self._cursor],
            )
            self._cursor += 1
            self._render_list()

    def on_key(self, event) -> None:
        if event.key == "enter":
            self.dismiss(self._apps)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "cancel-btn":
            self.dismiss(None)
        elif event.button.id == "save-btn":
            self.dismiss(self._apps)


class ContextMenu(ModalScreen):
    """Right-click context menu for an icon."""

    BINDINGS = [
        Binding("escape", "dismiss", "Close"),
        Binding("up", "focus_prev", show=False),
        Binding("down", "focus_next", show=False),
    ]

    _BUTTON_IDS = ["launch-btn", "edit-btn", "reorder-btn", "remove-btn"]

    def __init__(self, app_data: dict, **kwargs) -> None:
        super().__init__(**kwargs)
        self._app_data = app_data

    def compose(self) -> ComposeResult:
        icon = self._app_data.get("icon", "▶")
        name = self._app_data.get("name", "App")
        with Container(id="context-menu"):
            yield Label(f"{icon}  {name}", classes="modal-title")
            yield Button("▶  Launch", id="launch-btn")
            yield Button("✎  Edit", id="edit-btn")
            yield Button("⇅  Reorder All", id="reorder-btn")
            yield Button("✕  Remove", id="remove-btn", classes="btn-danger")

    def on_mount(self) -> None:
        self.query_one("#launch-btn").focus()

    def _focused_index(self) -> int:
        focused = self.focused
        for i, bid in enumerate(self._BUTTON_IDS):
            if focused and focused.id == bid:
                return i
        return 0

    def action_focus_next(self) -> None:
        idx = (self._focused_index() + 1) % len(self._BUTTON_IDS)
        self.query_one(f"#{self._BUTTON_IDS[idx]}").focus()

    def action_focus_prev(self) -> None:
        idx = (self._focused_index() - 1) % len(self._BUTTON_IDS)
        self.query_one(f"#{self._BUTTON_IDS[idx]}").focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        self.dismiss(event.button.id)


class ConfirmModal(ModalScreen):
    """Delete confirmation dialog."""

    BINDINGS = [Binding("escape", "dismiss", "Cancel")]

    def __init__(self, name: str, **kwargs) -> None:
        super().__init__(**kwargs)
        self._name = name

    def compose(self) -> ComposeResult:
        with Container(id="confirm-container"):
            yield Label("Remove App", classes="modal-title")
            yield Label(f'\nRemove "[bold]{self._name}[/bold]" from the desktop?\n')
            with Horizontal(classes="modal-buttons"):
                yield Button("Cancel", id="cancel-btn", classes="btn-cancel")
                yield Button("Remove", id="delete-btn", classes="btn-danger")

    def on_mount(self) -> None:
        self.query_one("#delete-btn").focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        self.dismiss(event.button.id == "delete-btn")


class TaroApp(App):
    """Taro Terminal Desktop."""

    CSS = TARO_CSS
    TITLE = "Taro Desktop"
    ENABLE_COMMAND_PALETTE = False

    BINDINGS = [
        Binding("q", "quit", "Quit", show=True),
        Binding("a", "add_app", "Add App", show=True),
        Binding("r", "reorder", "Reorder", show=True),
        Binding("f1", "help_keys", "Help", show=False),
        Binding("left", "nav(-1)", "←", show=False),
        Binding("right", "nav(1)", "→", show=False),
        Binding("up", "nav(-6)", "↑", show=False),
        Binding("down", "nav(6)", "↓", show=False),
        Binding("shift+left", "move_icon(-1)", "move ←", show=False),
        Binding("shift+right", "move_icon(1)", "move →", show=False),
        Binding("shift+up", "move_icon(-6)", "move ↑", show=False),
        Binding("shift+down", "move_icon(6)", "move ↓", show=False),
    ]

    GRID_COLS = 6

    def __init__(self, **kwargs) -> None:
        super().__init__(**kwargs)
        self._apps: list[dict] = load_apps()

    def compose(self) -> ComposeResult:
        with Horizontal(id="header-bar"):
            yield Label(" 🌸 Taro Desktop", id="title")
            with Horizontal(id="header-buttons"):
                yield Button("+ Add", id="add-btn")
                yield Button("✕ Quit", id="quit-btn")
        with ScrollableContainer(id="desktop"):
            for i, app_data in enumerate(self._apps):
                yield AppIcon(app_data, i, id=f"icon-{i}")
        yield Label(self._status_text(), id="status-bar")

    def on_mount(self) -> None:
        icons = list(self.query(AppIcon))
        if icons:
            icons[0].focus()

    def action_move_icon(self, delta: int) -> None:
        icons = list(self.query(AppIcon))
        focused = self.focused
        if focused not in icons:
            return
        idx = icons.index(focused)
        new_idx = (idx + delta) % len(self._apps)
        self._apps[idx], self._apps[new_idx] = self._apps[new_idx], self._apps[idx]
        save_apps(self._apps)
        self.call_later(self._rebuild_desktop, new_idx)

    def action_reorder(self) -> None:
        self.open_reorder()

    def action_nav(self, delta: int) -> None:
        icons = list(self.query(AppIcon))
        if not icons:
            return
        focused = self.focused
        if focused in icons:
            idx = (icons.index(focused) + delta) % len(icons)
        else:
            idx = 0
        icons[idx].focus()

    def _status_text(self) -> str:
        mode = "tmux/byobu (opens in new tab)" if in_multiplexer() else "standalone"
        return (
            f" [click] Launch  [right-click / e] Edit  [del] Delete  [a] Add  [q] Quit"
            f"    mode: {mode}"
        )

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "add-btn":
            self.action_add_app()
        elif event.button.id == "quit-btn":
            self.exit()

    def action_add_app(self) -> None:
        def handle(result):
            if result:
                self._apps.append(result)
                save_apps(self._apps)
                self.call_later(self._rebuild_desktop)

        self.push_screen(AddEditModal(), handle)

    def open_context_menu(self, index: int) -> None:
        if index >= len(self._apps):
            return

        def handle(action: str | None) -> None:
            if action == "launch-btn":
                self.do_launch(self._apps[index]["command"])
            elif action == "edit-btn":
                self.open_edit(index)
            elif action == "reorder-btn":
                self.open_reorder()
            elif action == "remove-btn":
                self.open_delete(index)

        self.push_screen(ContextMenu(self._apps[index]), handle)

    def open_reorder(self) -> None:
        def handle(result: list[dict] | None) -> None:
            if result is not None:
                self._apps = result
                save_apps(self._apps)
                self.call_later(self._rebuild_desktop)

        self.push_screen(ReorderModal(self._apps), handle)

    def open_edit(self, index: int) -> None:
        if index >= len(self._apps):
            return

        def handle(result):
            if result:
                self._apps[index] = result
                save_apps(self._apps)
                self.call_later(self._rebuild_desktop)

        self.push_screen(AddEditModal(app_data=self._apps[index], index=index), handle)

    def open_delete(self, index: int) -> None:
        if index >= len(self._apps):
            return
        name = self._apps[index].get("name", "App")

        def handle(confirmed):
            if confirmed:
                self._apps.pop(index)
                save_apps(self._apps)
                self.call_later(self._rebuild_desktop)

        self.push_screen(ConfirmModal(name=name), handle)

    def do_launch(self, command: str) -> None:
        if in_multiplexer():
            self.notify(f"Opening in new tab: {command}", timeout=2)
            launch_command(command)
        else:
            self.exit(result=command)

    async def _rebuild_desktop(self, focus_index: int = 0) -> None:
        desktop = self.query_one("#desktop", ScrollableContainer)
        await desktop.remove_children()
        for i, app_data in enumerate(self._apps):
            await desktop.mount(AppIcon(app_data, i, id=f"icon-{i}"))
        icons = list(self.query(AppIcon))
        if icons:
            icons[max(0, min(focus_index, len(icons) - 1))].focus()

    def action_help_keys(self) -> None:
        self.notify(
            "[click] Launch  [right-click/e] Edit  [del] Delete  [a] Add  [q] Quit",
            title="Keybindings",
            timeout=4,
        )


def main():
    while True:
        app = TaroApp()
        result = app.run()
        if result and not in_multiplexer():
            subprocess.run(["sh", "-c", result])
        else:
            break


if __name__ == "__main__":
    main()
